{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".indexOn": ["jgId", "handle"],
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('verified').val() === true)",
        "admin": {
          ".read": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true",
          ".write": false
        },
        "blocked": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        },
        "contacts": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        },
        "ban": {
          ".write": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true"
        }
      }
    },
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('verified').val() === true)",
        ".write": false,
        "verified": {
          ".read": true,
          ".write": false
        }
      }
    },
    "userGroups": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "userBroadcasts": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('verified').val() === true)",
        "$notifId": {
          ".validate": "newData.hasChildren(['type', 'title', 'message', 'timestamp']) && newData.child('timestamp').val() <= now"
        }
      }
    },
    "requests": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        "$senderUid": {
          ".write": "auth != null && auth.uid != $uid && auth.uid == $senderUid && !root.child('users').child($uid).child('blocked').child($senderUid).exists() && !root.child('users').child($senderUid).child('blocked').child($uid).exists()"
        }
      }
    },
    "chats": {
      "$roomId": {
        ".read": "auth != null && $roomId.contains(auth.uid)",
        ".write": "auth != null && $roomId.contains(auth.uid)",
        "messages": {
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".write": "auth != null && auth.uid == newData.child('sender').val() && $roomId.contains(auth.uid)"
          }
        }
      }
    },
    "chat-list": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid == $uid || auth.uid == $friendUid)"
        }
      }
    },
    "groups": {
      "$groupId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || data.child('admins').child(auth.uid).exists())",
        "admins": {
          ".write": "auth != null && data.child('admins').child(auth.uid).exists()"
        },
        "members": {
          "$memberUid": {
            ".write": "auth != null && (root.child('groups').child($groupId).child('admins').child(auth.uid).exists() || (auth.uid == $memberUid && newData.numChildren() == 1))"
          }
        }
      }
    },
    "groupMessages": {
      "$groupId": {
        ".read": "auth != null && root.child('groups').child($groupId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && root.child('groups').child($groupId).child('members').child(auth.uid).exists() && auth.uid == newData.child('sender').val()",
        ".indexOn": ["timestamp"]
      }
    },
    "broadcasts": {
      "$channelId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || data.child('admins').child(auth.uid).exists())",
        "admins": {
          ".write": "auth != null && data.child('admins').child(auth.uid).exists()"
        },
        "members": {
          "$memberUid": {
            ".write": "auth != null && (root.child('broadcasts').child($channelId).child('admins').child(auth.uid).exists() || (auth.uid == $memberUid && newData.numChildren() == 1))"
          }
        }
      }
    },
    "broadcastMessages": {
      "$channelId": {
        ".read": "auth != null && root.child('broadcasts').child($channelId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && root.child('broadcasts').child($channelId).child('members').child(auth.uid).exists() && auth.uid == newData.child('sender').val()",
        ".indexOn": ["timestamp"]
      }
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true",
      ".write": "auth != null && (root.child('admins').child(auth.uid).child('verified').val() === true || auth.uid == newData.child('reporterUid').val())",
      "$reportId": {
        "reporterUid": {
          ".validate": "newData.val() === auth.uid"
        },
        "reportType": {
          ".validate": "newData.val() === 'user_harassment' || newData.val() === 'user_spam' || newData.val() === 'user_inappropriate' || newData.val() === 'other'"
        },
        "verdict": {
          ".write": "root.child('admins').child(auth.uid).child('verified').val() === true"
        }
      }
    },
    "appeals": {
      "$appealId": {
        ".read": "auth != null && (auth.uid == data.child('userId').val() || root.child('admins').child(auth.uid).child('verified').val() === true)",
        ".write": "auth != null && (!data.exists() || auth.uid == data.child('userId').val() || root.child('admins').child(auth.uid).child('verified').val() === true)"
      }
    },
    "banned": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('verified').val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true"
      }
    },
    "adminLogs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true",
      ".write": false
    },
    "stats": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('verified').val() === true",
      ".write": false
    }
  }
}
